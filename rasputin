#!/usr/bin/env bash
#
# RASPUTIN BOOT SEQUENCE
# Deterministic Local Coding System
#
# Usage:
#   rasputin                    - Launch interactive TUI mode
#   rasputin tui [path]         - Launch TUI mode (explicit)
#   rasputin forge <path>       - Launch Deep Forge autonomous mode
#

set -euo pipefail

# ------------------------------------------------------------------------------
# CONFIGURATION
# ------------------------------------------------------------------------------

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$ROOT_DIR/rasputin.json"
REQUIRED_MODEL="qwen2.5-coder:14b"
OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"
PROFILE_NAME="Rasputin OCR"

# Parse command mode
RASPUTIN_MODE="tui"
WORKSPACE_PATH=""

if [[ $# -gt 0 ]]; then
    case "$1" in
        forge|f)
            RASPUTIN_MODE="forge"
            WORKSPACE_PATH="${2:-$(pwd)}"
            ;;
        tui|t)
            RASPUTIN_MODE="tui"
            WORKSPACE_PATH="${2:-$(pwd)}"
            ;;
        --help|-h)
            echo "Usage: rasputin [MODE] [PATH]"
            echo ""
            echo "Modes:"
            echo "  (none)       Launch interactive TUI mode (default)"
            echo "  tui [path]   Launch TUI mode explicitly"
            echo "  forge <path> Launch Deep Forge autonomous mode"
            echo ""
            echo "Deep Forge: Air-gapped, self-exhausting code refinement"
            echo "  - 100% local operation via Ollama"
            echo "  - Runs until no flaws remain"
            echo "  - Auto-commits fixes with git"
            echo ""
            exit 0
            ;;
        -*)
            echo "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
        *)
            # Assume it's a path
            WORKSPACE_PATH="$1"
            ;;
    esac
else
    WORKSPACE_PATH="$(pwd)"
fi

# ANSI color codes
CLR_RESET="\033[0m"
CLR_DIM="\033[2m"
CLR_BOLD="\033[1m"
CLR_GREEN="\033[32m"
CLR_CYAN="\033[36m"
CLR_YELLOW="\033[33m"
CLR_RED="\033[31m"
CLR_MAGENTA="\033[35m"

# Timing
DELAY_STAGE=0.4
DELAY_CHECK=0.15

ensure_terminal_profile() {
    if [[ "$(uname -s)" != "Darwin" ]] || [[ "${TERM_PROGRAM:-}" != "Apple_Terminal" ]]; then
        return
    fi

    if command -v python3 >/dev/null 2>&1; then
        python3 "$ROOT_DIR/support/install_terminal_profile.py" --quiet >/dev/null 2>&1 || true
    fi

    osascript -e "
tell application \"Terminal\"
    set profileName to \"$PROFILE_NAME\"
    set availableProfiles to name of every settings set
    if availableProfiles contains profileName then
        try
            set current settings of selected tab of front window to settings set profileName
        on error
            try
                set current settings of front window to settings set profileName
            end try
        end try
    end if
end tell
" >/dev/null 2>&1 || true
}

# ------------------------------------------------------------------------------
# VISUAL PRIMITIVES
# ------------------------------------------------------------------------------

