    echo -e "${CLR_DIM}                     .        ·        .        ·                     .        ·        .        ·                     .        ·        .        ·     ·${CLR_RESET}"
    echo -e "${CLR_DIM}                .        ·        .        ·                .        ·        .        ·                .        ·        .        ·                .        ·        .${CLR_RESET}"
    echo ""
    echo -e "${CLR_BOLD}${CLR_RED}РАС·ПУ·ТИН>>РАС      РАС·ПУ·ТИН         РАС·ПУ·ТИН>>РАС      РАС·ПУ·ТИН>>РАС      РАС|      ПУ·ТИН     РАС·ПУ·ТИН>>РАС           РАС·ПУ·ТИН         РАС|      ПУ·ТИН${CLR_RESET}"
    echo -e "${CLR_BOLD}${CLR_RED}РАС|      ПУ·ТИН     РАС|      ПУ·ТИН   РАС|                 РАС|      ПУ·ТИН     РАС|      ПУ·ТИН           РАС|                   РАС|            РАС>>     ПУ·ТИН${CLR_RESET}"
    echo -e "${CLR_BOLD}${CLR_RED}РАС·ПУ·ТИН>>РАС      РАС·ПУ·ТИН>>РАС·   РАС·ПУ·ТИН>>РАС      РАС·ПУ·ТИН>>РАС      РАС|      ПУ·ТИН           РАС|                   РАС|            РАС|>>    ПУ·ТИН${CLR_RESET}"
    echo -e "${CLR_BOLD}${CLR_RED}РАС|   >>ПУ·ТИН      РАС|      ПУ·ТИН            >>ПУ·ТИН    РАС|                 РАС|      ПУ·ТИН           РАС|                   РАС|            РАС| >>   ПУ·ТИН${CLR_RESET}"
    echo -e "${CLR_BOLD}${CLR_RED}РАС|      >>ПУ·Т     РАС|      ПУ·ТИН              ПУ·ТИН    РАС|                 РАС|      ПУ·ТИН           РАС|                   РАС|            РАС|  >>  ПУ·ТИН${CLR_RESET}"
    echo -e "${CLR_BOLD}${CLR_RED}РАС|        >>ПУ     РАС|      ПУ·ТИН   РАС|      ПУ·ТИН     РАС|                 РАС|      ПУ·ТИН           РАС|                   РАС|            РАС|   >> ПУ·ТИН${CLR_RESET}"
    echo -e "${CLR_BOLD}${CLR_RED}РАС|          >>     РАС|      ПУ·ТИН   РАС·ПУ·ТИН>>РАС      РАС|                 РАС·ПУ·ТИН>>РАС            РАС|                РАС·ПУ·ТИН         РАС|    >>ПУ·ТИН${CLR_RESET}"
